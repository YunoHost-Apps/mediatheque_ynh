#!/bin/bash
# Mise à jour Médiathèque — paquet YunoHost

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

# data_dir est géré par la ressource YunoHost — ne pas écraser moncine.db ni les affiches.
ynh_setup_source --dest_dir="$install_dir" --full_replace

#=================================================
# MIGRATIONS SQL
#=================================================
ynh_script_progression "Application des migrations SQL…"

mediatheque_bootstrap_data_files

mediatheque_run_migrate

#=================================================
# REAPPLY SYSTEM CONFIGURATIONS
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

mediatheque_configure_php_limits

ynh_config_add_phpfpm

ynh_config_add_nginx

mediatheque_fix_data_permissions

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
