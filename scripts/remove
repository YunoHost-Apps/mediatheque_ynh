#!/bin/bash
# Désinstallation Médiathèque — paquet YunoHost

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# SUPPRESSION DE LA CONFIG SYSTÈME
#=================================================
ynh_script_progression "Suppression de la configuration système de ${app}…"

ynh_config_remove_nginx
ynh_config_remove_phpfpm

if [[ -n "${data_dir:-}" && -d "${data_dir}" ]]; then
    ynh_script_progression "Suppression du dossier de données ${data_dir}…"
    ynh_safe_rm "${data_dir}"
fi

#=================================================
# FIN
#=================================================
ynh_script_progression "Désinstallation de ${app} terminée."
